{
  "name": "uask-chatbot-qa",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "npx playwright test",
    "test:positive": "npx playwright test tests/positive/",
    "test:negative": "npx playwright test tests/negative/",
    "test:edge": "npx playwright test tests/edge/",
    "test:security": "npx playwright test tests/security/",
    "test:quality": "npx playwright test tests/quality/",
    "test:e2e": "npx playwright test tests/e2e/",
    "test:api": "npx playwright test tests/api/ --project=api",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report reports/html-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "tsc": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.5",
    "typescript": "^5.9.3"
  }
}
